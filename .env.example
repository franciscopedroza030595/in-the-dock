# ── Celo Sepolia Testnet (Chain ID: 11142220) ─────────────────────────────
# RPC (optional — defaults to public Forno endpoint)
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# Deployed contract addresses (fill in after running: forge script Deploy)
NEXT_PUBLIC_POT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_USDT_ADDRESS=0x0000000000000000000000000000000000000000

# WalletConnect — get a free project ID at cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ── Server / Cron ─────────────────────────────────────────────────────────
# Random string — used as Bearer token to protect /api/cron/roll-day
CRON_SECRET=change-me-to-a-random-string

# Operator wallet private key — calls rollDay() daily at midnight UTC
# Fund it with testnet CELO from faucet.celo.org/celo-sepolia
OPERATOR_PRIVATE_KEY=0x...
